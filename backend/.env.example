NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opsflow_core?schema=public

# Auth and cookies
JWT_SECRET=change-this-to-a-strong-secret-with-at-least-32-chars
JWT_EXPIRES_IN=8h
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# API access and network
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false
JSON_BODY_LIMIT=256kb

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
PUBLIC_WRITE_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_WRITE_RATE_LIMIT_MAX=50
CHECKIN_RATE_LIMIT_WINDOW_MS=60000
CHECKIN_RATE_LIMIT_MAX=120

# Seed users (development/demo)
ADMIN_EMAIL=admin@opsflow.local
ADMIN_PASSWORD=Admin@123
MASTER_EMAIL=owner@opsflow.local
MASTER_PASSWORD=Master@123
GATE_EMAIL=operator@opsflow.local
GATE_PASSWORD=Gate@123
SCANNER_EMAIL=scanner@opsflow.local
SCANNER_PASSWORD=Scanner@123
GOVERNANCE_EMAIL=governance@opsflow.local
GOVERNANCE_PASSWORD=Governance@123

# Legacy aliases kept for backward compatibility with older setups
LEITOR_EMAIL=
LEITOR_PASSWORD=
COMISSAO_EMAIL=
COMISSAO_PASSWORD=
