generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Categoria {
  EXPOSITOR
  CAFEICULTOR
  VISITANTE
  IMPRENSA
  COMISSAO_ORGANIZADORA
  COLABORADOR_TERCEIRIZADO
}

enum StatusCredenciamento {
  CADASTRADO
  APROVADO
  BLOQUEADO
  CHECKED_IN
  INATIVO
}

enum StatusCredencial {
  GERADA
  ATIVA
  INATIVA
  UTILIZADA
  CANCELADA
}

enum TipoEventoSistema {
  CREDENCIAMENTO_CRIADO
  CREDENCIAL_GERADA
  DADOS_ATUALIZADOS
  ACESSO_VALIDADO
  ACESSO_NEGADO
}

enum AdminRole {
  MASTER_ADMIN
  ADMIN
  OPERADOR_QR
  LEITOR_CATRACA
  APP_GATE
  SYSTEM
}

enum AccessResult {
  ALLOW
  DENY
}

enum AccessReason {
  CREDENCIAL_INVALIDA
  CREDENCIAL_BLOQUEADA
  JA_UTILIZADA
  FORA_DO_HORARIO
  ACESSO_PERMITIDO
  CREDENCIAL_CANCELADA
  CREDENCIAL_INATIVA
}

enum AuditActorType {
  ADMIN_USER
  APP_GATE
  SYSTEM
}

model Credenciado {
  id                   String               @id @default(uuid()) @db.Uuid
  eventoId             String?              @db.Uuid
  categoria            Categoria
  statusCredenciamento StatusCredenciamento @default(CADASTRADO)
  nomeCompleto         String
  cpf                  String?              @unique
  celular              String
  email                String               @unique
  municipio            String
  uf                   String
  nacionalidade        String?
  tipoCombustivel      String?
  cidadeOrigem         String?
  combustivel          String?
  distanciaKm          Float?
  pegadaCarbonoEstimada Float?
  pcd                  Boolean              @default(false)
  aceitouLgpd          Boolean

  cnpj            String?
  siteEmpresa     String?
  nomeEmpresa     String?
  ccir            String?
  nomePropriedade String?
  nomeVeiculo     String?
  funcaoCargo     String?

  credencial             Credencial?
  eventos                EventoSistema[]
  evento                 Evento?                 @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  descarbonizacaoRegistros DescarbonizacaoRegistro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria, statusCredenciamento])
  @@index([eventoId])
}

model Credencial {
  id              String           @id @default(uuid()) @db.Uuid
  credenciadoId   String           @unique @db.Uuid
  codigoUnico     String           @unique
  qrCodePayload   String
  statusCredencial StatusCredencial @default(GERADA)
  emitidaEm       DateTime

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)
  accessAttempts AccessAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventoSistema {
  id            String           @id @default(uuid()) @db.Uuid
  credenciadoId String?          @db.Uuid
  tipoEvento    TipoEventoSistema
  descricao     String
  metadata      Json?
  createdAt     DateTime         @default(now())

  credenciado Credenciado? @relation(fields: [credenciadoId], references: [id], onDelete: SetNull)

  @@index([credenciadoId])
  @@index([tipoEvento])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  nome         String
  role         AdminRole @default(ADMIN)
  ativo        Boolean  @default(true)
  permissoesCustomizadas Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]
  operatedAccessAttempts AccessAttempt[] @relation("OperatorAccessAttempts")
}

model AuditLog {
  id         String         @id @default(uuid()) @db.Uuid
  actorType  AuditActorType
  actorId    String?        @db.Uuid
  acao       String
  recurso    String
  recursoId  String?
  detalhes   Json?
  createdAt  DateTime       @default(now())

  actor AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorType, createdAt])
  @@index([recurso, recursoId])
}

model GateDevice {
  id          String   @id @default(uuid()) @db.Uuid
  codigo      String   @unique
  nome        String
  localizacao String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accessAttempts AccessAttempt[]
}

model AccessAttempt {
  id           String       @id @default(uuid()) @db.Uuid
  credencialId String?      @db.Uuid
  gateDeviceId String?      @db.Uuid
  operatorId   String?      @db.Uuid
  operatorNome String?
  operatorRole String?
  deviceId     String?
  deviceInfo   Json?
  accessPoint  String?
  resultado    AccessResult
  motivo       AccessReason
  metadata     Json?
  createdAt    DateTime     @default(now())

  credencial Credencial? @relation(fields: [credencialId], references: [id], onDelete: SetNull)
  gateDevice GateDevice? @relation(fields: [gateDeviceId], references: [id], onDelete: SetNull)
  operator   AdminUser?  @relation("OperatorAccessAttempts", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([credencialId, createdAt])
  @@index([resultado, motivo, createdAt])
  @@index([operatorId, createdAt])
  @@index([deviceId, createdAt])
}

model Evento {
  id          String       @id @default(uuid()) @db.Uuid
  nomeEvento  String
  isGratuito  Boolean      @default(true)
  ativo       Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  credenciados Credenciado[]
}

model DescarbonizacaoRegistro {
  id              String    @id @default(uuid()) @db.Uuid
  credenciadoId   String    @db.Uuid
  cidadeOrigem    String
  cidadeDestino   String    @default("Franca")
  combustivel     String
  distanciaKm     Float
  emissaoKgCo2    Float
  fatorEmissao    Float
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@index([credenciadoId, createdAt])
}
